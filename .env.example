# AEGISFLOW Environment Variables
# Copy to .env and fill in your values

# Cerebras / Gemma 4
CEREBRAS_API_KEY=

# Application
DEBUG=true
HOST=0.0.0.0
PORT=8000

# In-memory state by default. Set REDIS_URL for production.
REDIS_URL=

# Slack
SLACK_TOKEN=
SLACK_CHANNEL=#aegisflow-incidents

# Jira
JIRA_URL=
JIRA_EMAIL=
JIRA_TOKEN=
JIRA_PROJECT=AEGIS

# Notion
NOTION_TOKEN=
NOTION_PAGE_ID=

# GitHub
GITHUB_TOKEN=

# Simulation
SIMULATION_ENABLED=true
SIMULATION_INTERVAL=10
